{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "ignoreDeprecations": "6.0",

        "rootDir": "./src",
        "outDir": "./dist",

        "strict": true,

        "esModuleInterop": true,

        "forceConsistentCasingInFileNames": true,

        "skipLibCheck": true,

        "resolveJsonModule": true,

        "types": ["node"],

        "noImplicitAny": true
    },

    "include": [
        "src"
    ],

    "exclude": [
        "node_modules",
        "dist", "prisma"
    ]
}